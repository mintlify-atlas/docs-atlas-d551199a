  "keyFeatures": [
    "Spotify-inspired dark theme with green accent colors",
    "Dynamic project showcase with 20+ personal projects",
    "Markdown-based blog system with frontmatter support",
    "GitHub contributions calendar integration",
    "Spotify album display integration",
    "Smooth animations using Framer Motion",
    "Responsive design with mobile navigation",
    "TypeScript for type safety",
    "Tailwind CSS for styling",
    "Vercel Analytics and Speed Insights",
    "Docker containerization support",
    "SEO optimized with Open Graph metadata"
