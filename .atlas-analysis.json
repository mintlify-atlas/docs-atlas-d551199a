    "Projects - Grid display of personal projects with filtering",
    "ExperienceItems - Timeline of work experience",
    "Skills - Technical skills showcase",
    "ProgrammingLanguages - Language proficiency display",
    "GithubContributions - GitHub activity calendar",
    "SpotifyAlbum - Currently playing or favorite album",
    "BlogPostList - List of blog posts with pagination",
    "BlogPostCard - Individual blog post preview card",
    "Navigation - Main navigation bar",
    "MobileNav - Mobile-responsive navigation menu",
    "Footer - Site footer with links",
    "Loader - Loading animation component",
    "Spotlight - Visual spotlight effect",
    "BackgroundGradient - Gradient background effect"
